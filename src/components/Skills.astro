<!-- ================================================================
  SKILLS SECTION
================================================================ -->
<section id="skills" class="flex min-h-screen items-center bg-white">
  <div class="mx-auto w-full max-w-screen-lg px-10">
    <!-- セクションラベル -->
    <p
      class="mb-5 font-mono text-[11px] font-medium tracking-[0.25em] text-slate-400"
    >
      SKILLS
    </p>

    <h2
      class="mb-14 text-[clamp(1.5rem,3vw,2rem)] font-semibold tracking-tight text-slate-900"
    >
      $ skills
    </h2>

    <div class="max-w-lg space-y-8">
      <!-- Cisco -->
      <div>
        <div class="mb-2.5 flex items-baseline justify-between">
          <span class="font-mono text-sm font-medium text-slate-800">Cisco</span
          >
          <span class="font-mono text-xs text-slate-400">80%</span>
        </div>
        <div class="h-[3px] w-full overflow-hidden rounded-full bg-slate-100">
          <div
            class="h-full w-4/5 rounded-full bg-slate-900"
            style="transition: width 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94)"
          >
          </div>
        </div>
      </div>

      <!-- Routing / BGP -->
      <div>
        <div class="mb-2.5 flex items-baseline justify-between">
          <span class="font-mono text-sm font-medium text-slate-800"
            >Routing / BGP</span
          >
          <span class="font-mono text-xs text-slate-400">75%</span>
        </div>
        <div class="h-[3px] w-full overflow-hidden rounded-full bg-slate-100">
          <div
            class="h-full w-3/4 rounded-full bg-slate-900"
            style="transition: width 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94)"
          >
          </div>
        </div>
      </div>

      <!-- Kubernetes -->
      <div>
        <div class="mb-2.5 flex items-baseline justify-between">
          <span class="font-mono text-sm font-medium text-slate-800"
            >Kubernetes</span
          >
          <span class="font-mono text-xs text-slate-400">65%</span>
        </div>
        <div class="h-[3px] w-full overflow-hidden rounded-full bg-slate-100">
          <div
            class="h-full w-2/3 rounded-full bg-slate-900"
            style="transition: width 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94)"
          >
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
