<!-- ================================================================
  NETWORK CANVAS SCRIPT
================================================================ -->
<script is:inline>
  if (typeof window !== "undefined") {
    const canvas = document.getElementById("network-bg");
    const ctx = canvas ? canvas.getContext("2d") : null;

    if (canvas && ctx) {
      const dpr = window.devicePixelRatio || 1;
      let animationId;

      const points = [];
      const POINT_COUNT = 36;

      function initPoints() {
        points.length = 0;
        for (let i = 0; i < POINT_COUNT; i++) {
          points.push({
            rx: Math.random(),
            ry: Math.random(),
            vx: (Math.random() - 0.5) * 0.12,
            vy: (Math.random() - 0.5) * 0.12,
            hub: Math.random() > 0.8,
            x: 0,
            y: 0,
          });
        }
      }

      function resizeCanvas() {
        const w = canvas.clientWidth;
        const h = canvas.clientHeight;
        canvas.width = w * dpr;
        canvas.height = h * dpr;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }

      function getMaxDist() {
        const w = canvas.clientWidth;
        if (w < 640) return 60;
        if (w < 1024) return 80;
        return 100;
      }

      function animate() {
        const w = canvas.clientWidth;
        const h = canvas.clientHeight;

        ctx.clearRect(0, 0, w, h);

        points.forEach((p) => {
          p.x = p.rx * w;
          p.y = p.ry * h;
        });

        const maxDist = getMaxDist();

        /* 接続線 */
        for (let i = 0; i < points.length; i++) {
          for (let j = i + 1; j < points.length; j++) {
            const dx = points[i].x - points[j].x;
            const dy = points[i].y - points[j].y;
            const dist = Math.sqrt(dx * dx + dy * dy);

            if (dist < maxDist) {
              let alpha = (1 - dist / maxDist) * 0.12;
              if (points[i].hub || points[j].hub) alpha *= 1.6;

              ctx.strokeStyle = `rgba(15,23,42,${alpha})`;
              ctx.lineWidth = dist < maxDist * 0.5 ? 0.9 : 0.6;

              ctx.beginPath();
              ctx.moveTo(points[i].x, points[i].y);
              ctx.lineTo(points[j].x, points[j].y);
              ctx.stroke();
            }
          }
        }

        /* ノード */
        points.forEach((p) => {
          ctx.fillStyle = p.hub
            ? "rgba(216,238,254,0.9)"
            : "rgba(15,23,42,0.35)";

          ctx.beginPath();
          ctx.arc(p.x, p.y, p.hub ? 2.2 : 1.5, 0, Math.PI * 2);
          ctx.fill();
        });

        /* 移動 */
        points.forEach((p) => {
          p.rx += p.vx / w;
          p.ry += p.vy / h;

          if (p.rx < 0 || p.rx > 1) p.vx *= -1;
          if (p.ry < 0 || p.ry > 1) p.vy *= -1;

          p.rx = Math.min(1, Math.max(0, p.rx));
          p.ry = Math.min(1, Math.max(0, p.ry));
        });

        animationId = requestAnimationFrame(animate);
      }

      /* 初期化 */
      resizeCanvas();
      initPoints();
      animate();

      window.addEventListener("resize", resizeCanvas);
      window.addEventListener("beforeunload", () => {
        if (animationId) cancelAnimationFrame(animationId);
      });
    }
  }
</script>
