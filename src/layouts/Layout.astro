---
import "../styles/global.css";
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>yumekiti | Network Engineer Portfolio</title>
    <meta
      name="description"
      content="ネットワーク技術で日常の当たり前を支える便利を設計するエンジニアのポートフォリオ。"
    />
    <meta name="robots" content="index, follow" />

    <meta property="og:title" content="yumekiti | Portfolio" />
    <meta property="og:description" content="Network Engineer Portfolio" />
    <meta property="og:type" content="website" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-white text-slate-900">
    <!-- SEO用ヘッダー（非表示） -->
    <header class="sr-only">
      <h1>yumekiti Portfolio</h1>
      <nav aria-label="Main navigation">
        <ul>
          <li><a href="#concept">Concept</a></li>
          <li><a href="#skills">Skills</a></li>
          <li><a href="#works">Works</a></li>
          <li><a href="#about">About</a></li>
        </ul>
      </nav>
    </header>

    <!-- 左ナビ（UI用） -->
    <nav
      aria-label="Section navigation"
      class="fixed top-1/2 left-6 z-50 hidden -translate-y-1/2 flex-col gap-5 lg:flex"
    >
      <a
        href="#concept"
        class="group relative flex items-center"
        aria-label="Concept section"
      >
        <div
          class="h-2.5 w-2.5 rounded-full bg-blue-300 opacity-40 transition-all group-hover:scale-110 group-hover:opacity-100"
        >
        </div>
        <span
          class="absolute left-5 text-xs whitespace-nowrap text-slate-400 opacity-0 transition-opacity group-hover:opacity-100"
        >
          Concept
        </span>
      </a>

      <a
        href="#skills"
        class="group relative flex items-center"
        aria-label="Skills section"
      >
        <div
          class="h-2.5 w-2.5 rounded-full bg-blue-300 opacity-40 transition-all group-hover:scale-110 group-hover:opacity-100"
        >
        </div>
        <span
          class="absolute left-5 text-xs whitespace-nowrap text-slate-400 opacity-0 transition-opacity group-hover:opacity-100"
        >
          Skills
        </span>
      </a>

      <a
        href="#works"
        class="group relative flex items-center"
        aria-label="Works section"
      >
        <div
          class="h-2.5 w-2.5 rounded-full bg-blue-300 opacity-40 transition-all group-hover:scale-110 group-hover:opacity-100"
        >
        </div>
        <span
          class="absolute left-5 text-xs whitespace-nowrap text-slate-400 opacity-0 transition-opacity group-hover:opacity-100"
        >
          Works
        </span>
      </a>

      <a
        href="#about"
        class="group relative flex items-center"
        aria-label="About section"
      >
        <div
          class="h-2.5 w-2.5 rounded-full bg-blue-300 opacity-40 transition-all group-hover:scale-110 group-hover:opacity-100"
        >
        </div>
        <span
          class="absolute left-5 text-xs whitespace-nowrap text-slate-400 opacity-0 transition-opacity group-hover:opacity-100"
        >
          About
        </span>
      </a>
    </nav>

    <!-- メイン -->
    <main>
      <slot />
    </main>
  </body>
</html>
